{
  "name": "chat-to-dom-editor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "electron:dev": "concurrently -k -n vite,electron -c cyan,magenta \"pnpm run dev\" \"wait-on http://127.0.0.1:5173 && electron electron/main.cjs\"",
    "electron:pack": "pnpm run build && electron-builder --dir",
    "electron:dist": "pnpm run build && electron-builder",
    "test": "jest",
    "build": "tsc --noEmit && vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts --host 0.0.0.0"
  },
  "build": {
    "appId": "dev.agentresume.app",
    "productName": "Resume Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "backend",
        "filter": [
          "resume-agent-api",
          "resume-agent-api.exe"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^1.23.0",
    "mobx": "^6.16.1",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sass": "^1.101.0",
    "ts-jest": "^29.2.5",
    "wait-on": "^9.0.10"
  }
}
