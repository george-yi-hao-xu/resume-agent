{
	"name": "chat-to-dom-editor",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.34.2",
	"type": "module",
	"author": "gyxu",
	"scripts": {
		"dev": "tsx watch --tsconfig tsconfig.json hono_bk_end/src/index.ts",
		"server:dev": "tsx watch --tsconfig tsconfig.json hono_bk_end/src/index.ts",
		"server:build": "tsc -p tsconfig.json",
		"server:test": "jest --config jest.server.config.cjs",
		"client:dev": "vite --config client/vite.config.ts --host 0.0.0.0",
		"client:test": "jest --config client/jest.config.cjs",
		"client:build": "tsc -p client/tsconfig.json && vite build --config client/vite.config.ts",
		"client:preview": "vite preview --config client/vite.config.ts --host 0.0.0.0",
		"test": "pnpm run server:test && pnpm run client:test",
		"build": "pnpm run server:build && pnpm run client:build",
		"preview": "pnpm run client:preview"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.27",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.27",
		"@nestjs/platform-express": "^11.1.27",
		"@repo/schema": "workspace:*",
		"@vitejs/plugin-react": "^4.3.4",
		"lucide-react": "^1.23.0",
		"mobx": "^6.16.1",
		"mobx-react-lite": "^4.1.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"typescript": "^5.7.2",
		"vite": "^6.0.7"
	},
	"devDependencies": {
		"@jest/globals": "^30.4.1",
		"@types/jest": "^29.5.14",
		"@types/node": "^26.1.0",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"@types/supertest": "^7.2.0",
		"dotenv": "^17.4.2",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"prettier": "^3.9.4",
		"sass": "^1.101.0",
		"supertest": "^7.2.2",
		"ts-jest": "^29.2.5",
		"tsx": "^4.22.5"
	}
}
